import { Button, ScrollView } from "std-widgets.slint";
import { KeyData } from "key_data.slint";
import { ConfirmDeleteDialog, RenameDialog } from "dialogs.slint";
import { ProfilePanel } from "profile_panel.slint";
import { SettingsPreview } from "settings_preview.slint";
import { KeyPropsPanel } from "key_props_panel.slint";
import { GlobalSettingsPanel } from "global_settings_panel.slint";

export component SettingsWindow inherits Window {
    min-height: 700px;
    title: "VSRG-KeyVisualizer config";
    background: #252525;
    always-on-top: true;

    // ===== 所有属性（保持与 Rust 端接口一致） =====
    in property <[KeyData]> root_preview_keys;
    in-out property <int> selected_index: -1;

    in-out property <int> current_x;
    in-out property <int> current_y;
    in-out property <int> current_w;
    in-out property <int> current_h;
    in-out property <string> current_color;
    in-out property <int> current_opacity_percent: 100;
    in-out property <int> current_bar_width_percent: 100;
    in-out property <bool> capturing_mode: false;
    in-out property <int> global_top_boundary: 0;
    in-out property <int> global_border_width: 1;
    in-out property <color> global_border_color: #ffffff;
    in-out property <string> global_border_color_hex: "#555555";
    in-out property <color> global_key_color: #333333;
    in-out property <string> global_key_color_hex: "#333333";
    in-out property <int> global_key_opacity_percent: 100;
    in-out property <int> key_margin_width: 4;
    in-out property <int> flow_direction: 0;
    in-out property <int> flow_speed: 4;
    in-out property <bool> front_line_emit: false;

    // Profile
    in property <[string]> profile_list;
    in-out property <int> profile_selected: -1;
    in property <string> current_profile_name;
    callback switch_to_profile(int);
    callback add_new_profile();
    callback rename_profile(int, string);
    callback delete_profile(int);
    in-out property <int> renaming_index: -1;
    in-out property <string> renaming_text;

    // 事件回调
    callback handle_canvas_pointer_down(int, int, bool);
    callback update_key_position(int, int, int, int, int);
    callback update_key_position_x(int, int, int, int);
    callback update_key_position_y(int, int, int, int);
    callback top_boundary_edited(int);
    callback key_margin_edited(int);
    callback add_new_key();
    callback save_config();
    callback update_key_size(int, int, int);
    callback update_key_color(int, string);
    callback update_key_opacity(int, int);
    callback border_color_edited(string);
    callback key_color_edited(string);
    callback key_opacity_edited(int);
    callback flow_direction_edited(int);
    callback flow_speed_edited(int);
    callback front_line_emit_toggled(bool);
    callback delete_key(int);
    callback update_key_bar_width_percent(int, int);
    callback delete_selected_keys();
    in-out property <bool> confirm_delete_visible: false;

    // 浮动参数面板位置（Rust 端维护，通过 callback 更新）
    in-out property <length> panel_x: 0px;
    in-out property <length> panel_y: 0px;
    callback panel_drag_start(int, int);  // 按下时传 (mouse_rel_x, mouse_rel_y)
    callback panel_drag_move(int, int);   // 拖拽中传 (mouse_rel_x, mouse_rel_y)
    callback panel_drag_end();            // 释放

    HorizontalLayout {
        padding: 15px;
        spacing: 15px;

        // ====== 左侧：Profile 列表 ======
        ProfilePanel {
            profile_list <=> root.profile_list;
            profile_selected <=> root.profile_selected;
            current_profile_name <=> root.current_profile_name;
            switch_to_profile(index) => { root.switch_to_profile(index); }
            add_new_profile => { root.add_new_profile(); }
            rename_profile(index, name) => { root.rename_profile(index, name); }
            delete_profile(index) => { root.delete_profile(index); }
            renaming_index <=> root.renaming_index;
            renaming_text <=> root.renaming_text;
        }

        // ====== 右侧容器：画布预览 + 浮动参数面板 ======
        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
            clip: false;

            VerticalLayout {
                spacing: 15px;
                horizontal-stretch: 1;

                Text {
                    text: "Location Preview (Drag to move, Click to select)";
                    color: #aaa;
                }

                preview_box := SettingsPreview {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    preview_keys <=> root.root_preview_keys;
                    key_margin_width <=> root.key_margin_width;
                    global_key_color <=> root.global_key_color;
                    selected_index <=> root.selected_index;
                    handle_canvas_pointer_down(x, y, ctrl) => { root.handle_canvas_pointer_down(x, y, ctrl); }
                    update_key_position(idx, mx, my, cw, ch) => { root.update_key_position(idx, mx, my, cw, ch); }
                    add_new_key => { root.add_new_key(); }
                    request_focus => { key_handler.focus(); }
                }
            }

            // 浮动参数面板（可拖拽，z 轴在前）
            param_panel := Rectangle {
                // x/y 使用面板当前绝对位置 panel_x/panel_y
                x: root.panel_x;
                y: Math.max(root.panel_y, 16px);
                width: 300px;
                init => {
                    root.panel_x = parent.width - 320px;
                    root.panel_y = 16px;
                    debug("[PANEL-DRAG] INIT: panel_xy=(", Math.round(root.panel_x / 1px), ",", Math.round(root.panel_y / 1px), ") parent.width=", Math.round(parent.width / 1px));
                }
                z: 1;
                background: #2a2a2a;
                border-radius: 8px;
                border-width: 1px;
                border-color: #555555;

                VerticalLayout {
                    spacing: 0px;
                    width: 100%;
                    height: 100%;

                    // 拖拽标题栏
                    Rectangle {
                        height: 28px;
                        background: #333333;
                        border-radius: 8px;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            pointer-event(event) => {
                                if (event.kind == PointerEventKind.down) {
                                    debug("[PANEL-DRAG] DOWN: pressed=(",
                                        Math.round(self.pressed-x / 1px), ",", Math.round(self.pressed-y / 1px),
                                        ") panel=(", Math.round(root.panel_x / 1px), ",", Math.round(root.panel_y / 1px), ")");
                                    root.panel_drag_start(Math.round(self.pressed-x / 1px), Math.round(self.pressed-y / 1px));
                                }
                                if (event.kind == PointerEventKind.up) {
                                    debug("[PANEL-DRAG] UP: panel=(",
                                        Math.round(root.panel_x / 1px), ",", Math.round(root.panel_y / 1px), ")");
                                    root.panel_drag_end();
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    root.panel_drag_move(Math.round(self.mouse-x / 1px), Math.round(self.mouse-y / 1px));
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            padding-left: 8px;
                            Text {
                                text: "⋮⋮";
                                color: #888;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Parameter Config";
                                color: #aaa;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 12px;
                            padding: 8px;

                        // Key Properties 面板
                        FocusScope {
                            KeyPropsPanel {
                                current_x <=> root.current_x;
                                current_y <=> root.current_y;
                                current_w <=> root.current_w;
                                current_h <=> root.current_h;
                                current_color <=> root.current_color;
                                current_opacity_percent <=> root.current_opacity_percent;
                                current_bar_width_percent <=> root.current_bar_width_percent;
                                selected_index <=> root.selected_index;
                                preview_width: Math.round(preview_box.width / 1px);
                                preview_height: Math.round(preview_box.height / 1px);
                                update_key_position_x(idx, val, cw, ch) => { root.update_key_position_x(idx, val, cw, ch); }
                                update_key_position_y(idx, val, cw, ch) => { root.update_key_position_y(idx, val, cw, ch); }
                                update_key_size(idx, w, h) => { root.update_key_size(idx, w, h); }
                                update_key_color(idx, c) => { root.update_key_color(idx, c); }
                                update_key_opacity(idx, v) => { root.update_key_opacity(idx, v); }
                                update_key_bar_width_percent(idx, v) => { root.update_key_bar_width_percent(idx, v); }
                            }
                        }

                        Rectangle { height: 1px; background: #AAAAAA; }

                        // Global Settings 面板
                        GlobalSettingsPanel {
                            global_key_color_hex <=> root.global_key_color_hex;
                            global_key_opacity_percent <=> root.global_key_opacity_percent;
                            global_border_color_hex <=> root.global_border_color_hex;
                            front_line_emit <=> root.front_line_emit;
                            flow_direction <=> root.flow_direction;
                            flow_speed <=> root.flow_speed;
                            global_top_boundary <=> root.global_top_boundary;
                            key_margin_width <=> root.key_margin_width;
                            key_color_edited(val) => { root.key_color_edited(val); }
                            key_opacity_edited(val) => { root.key_opacity_edited(val); }
                            border_color_edited(val) => { root.border_color_edited(val); }
                            front_line_emit_toggled(val) => { root.front_line_emit_toggled(val); }
                            flow_direction_edited(val) => { root.flow_direction_edited(val); }
                            flow_speed_edited(val) => { root.flow_speed_edited(val); }
                            top_boundary_edited(val) => { root.top_boundary_edited(val); }
                            key_margin_edited(val) => { root.key_margin_edited(val); }
                        }

                        Rectangle { height: 1px; background: #AAAAAA; }

                        HorizontalLayout {
                            spacing: 15px;
                            Button {
                                text: "Delete Selected Key";
                                enabled: root.selected_index != -1;
                                clicked => { root.confirm_delete_visible = true; }
                            }
                            Button {
                                text: "Save Config & Close";
                                primary: true;
                                clicked => { root.save_config(); }
                            }
                        }

                        key_handler := FocusScope {
                            enabled: root.selected_index != -1;
                            key-pressed(ev) => {
                                if (ev.text == "" || ev.text == "\u{7f}") {
                                    root.confirm_delete_visible = true;
                                    accept
                                } else { reject }
                            }
                        } // ~ key_handler
                    } // ~ ScrollView.inner VerticalLayout
                } // ~ ScrollView
            } // ~ param_panel VerticalLayout
        } // ~ param_panel Rectangle
    } // ~ 右侧容器 Rectangle
} // ~ HorizontalLayout (外层)

    // ====== 弹窗 ======
    ConfirmDeleteDialog {
        is_visible: root.confirm_delete_visible;
        confirmed => {
            root.confirm_delete_visible = false;
            root.delete_selected_keys();
        }
        cancelled => { root.confirm_delete_visible = false; }
    }

    RenameDialog {
        is_visible: root.renaming_index >= 0;
        current_name: root.renaming_text;
        edit_text: root.renaming_text;
        accepted(new_name) => {
            root.rename_profile(root.renaming_index, new_name);
            root.renaming_index = -1;
        }
        cancelled => { root.renaming_index = -1; }
    }

    // 按键捕获模式遮罩层
    TouchArea {
        visible: root.capturing_mode;
        width: parent.width;
        height: parent.height;
        x: 0;
        y: 0;
        enabled: root.capturing_mode;
    }
} // ~ SettingsWindow
