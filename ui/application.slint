import { Button, LineEdit, SpinBox } from "std-widgets.slint";

// 定义结构体（放在组件外部，使所有组件都能访问）
export struct KeyData {
    name: string,
    display_name: string,
    is_pressed: bool,
    x: length,
    y: length,
    w: length,
    h: length,
    pressed_color: color,
    color_hex: string,
}

export component SettingsWindow inherits Window {
    min-width: 600px;
    min-height: 520px; // 微调高度以稳妥容纳所有配置元素
    title: "KeyTick config";
    background: #252525;
    always-on-top: true;

    // 新增：全局步进属性（由 Rust 注入，UI 内部读写）
    in-out property <int> global_grid_size: 4;

    // 新增：当步进被修改时通知 Rust 的回调
    callback grid_size_edited(int);

    // --- 核心属性声明 ---
    in property <[KeyData]> root_preview_keys;
    in-out property <int> selected_index: -1;

    in-out property <int> current_x;
    in-out property <int> current_y;
    in-out property <int> current_w;
    in-out property <int> current_h;
    in-out property <string> current_color;

    in-out property <bool> capturing_mode: false;

    // --- 回调通知 Rust ---
    callback update_key_config(int, int, int, int, int, string);
    callback add_new_key();
    callback delete_key(int); // 👈 新增：删除按键的回调
    callback save_config_clicked();
    callback close_clicked();

    VerticalLayout {
        padding: 20px;
        spacing: 15px;

        Text {
            text: "Location Preview (Drag to move, Click to select)";
            color: #aaa;
        }
// ✨ 支持动态可变边界的预览框容器
        preview_box := Rectangle {
            min-height: 180px;
            min-width: 560px; // 允许横向被拉得更宽
            background: #1a1a1a;
            border-radius: 4px;
            clip: true;

            for key[i] in root.root_preview_keys: Rectangle {
                x: key.x;
                y: key.y;
                width: key.w;
                height: key.h;

                background: root.selected_index == i ? #4A90E2 : #444;
                border-width: 2px;
                border-color: root.selected_index == i ? white : transparent;

                Text {
                    text: key.display_name;
                    color: white;
                }

                TouchArea {
                    // 用于缓存刚点击下去时鼠标在按钮内部的相对初始偏移
                    property <length> offset_x;
                    property <length> offset_y;

                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down) {
                            root.selected_index = i;
                            root.current_x = key.x / 1px;
                            root.current_y = key.y / 1px;
                            root.current_w = key.w / 1px;
                            root.current_h = key.h / 1px;
                            root.current_color = key.color_hex;

                            self.offset_x = self.pressed-x;
                            self.offset_y = self.pressed-y;
                        }
                    }

                    moved => {
                        if (self.pressed) {
                            let target_x = (key.x / 1px) + (self.mouse-x - self.offset_x) / 1px;
                            let target_y = (key.y / 1px) + (self.mouse-y - self.offset_y) / 1px;
        
                            // 使用动态的全局步进属性进行四舍五入吸附
                            let g_size = Math.max(1, root.global_grid_size); // 避免除以 0
                            let snapped_x = Math.round(target_x / g_size) * g_size;
                            let snapped_y = Math.round(target_y / g_size) * g_size;

                            let max_x = (preview_box.width - key.w) / 1px;
                            let max_y = (preview_box.height - key.h) / 1px;

                            root.current_x = Math.max(0, Math.min(snapped_x, Math.max(0, max_x)));
                            root.current_y = Math.max(0, Math.min(snapped_y, Math.max(0, max_y)));

                            root.sync_inputs_to_memory();
                        }
                    }
                }
            }

            Button {
                text: "+ Add Key";
                x: parent.width - 110px;
                y: parent.height - 40px;
                clicked => {
                    root.add_new_key();
                }
            }
        }

        Text {
            text: "Parameter Config";
            color: #aaa;
        }

        // 参数编辑网格表单
        GridLayout {
            spacing: 10px;
            Row {
                Text {
                    text: "Location X:";
                    vertical-alignment: center;
                }

                current_x_input := SpinBox {
                    value: root.current_x;
                    step-size: root.global_grid_size; // 完美同步：点击加减箭头也跟随全局步进
                    enabled: root.selected_index != -1;
                    edited => {
                        root.current_x = self.value;
                        root.sync_inputs_to_memory();
                    }
                }

                Text {
                    text: "Location Y:";
                    vertical-alignment: center;
                }

                current_y_input := SpinBox {
                    value: root.current_y;
                    step-size: root.global_grid_size; // 完美同步：点击加减箭头也跟随全局步进
                    enabled: root.selected_index != -1;
                    edited => {
                        root.current_y = self.value;
                        root.sync_inputs_to_memory();
                    }
                }
            }

            Row {
                Text {
                    text: "Width W:";
                    vertical-alignment: center;
                }

                current_w_input := SpinBox {
                    value: root.current_w;
                    enabled: root.selected_index != -1;
                    edited => {
                        root.current_w = self.value;
                        root.sync_inputs_to_memory();
                    }
                }
                Text {
                    text: "Height H:";
                    vertical-alignment: center;
                }

                current_h_input := SpinBox {
                    value: root.current_h;
                    enabled: root.selected_index != -1;
                    edited => {
                        root.current_h = self.value;
                        root.sync_inputs_to_memory();
                    }
                }
            }

            Row {
                Text {
                    text: "Pressed Color:";
                    vertical-alignment: center;
                }

                current_col_input := LineEdit {
                    text: root.current_color;
                    enabled: root.selected_index != -1;
                    edited => {
                        root.current_color = self.text;
                        root.sync_inputs_to_memory();
                    }
                }
                Text {
                    text: "Global Grid Snapping (px):";
                    vertical-alignment: center;
                    color: #fff;
                }

                SpinBox {
                    value: root.global_grid_size;
                    step-size: 1; // 步进输入框本身每次可以 +1 或 -1
                    // min: 1;       // 限制最小为 1px 吸附（即自由移动）
                    // max: 50;      // 限制最大吸附大小
                    edited => {
                        root.global_grid_size = self.value;
                        // 触发回调实时把新步长告诉 Rust 内存
                        root.grid_size_edited(self.value);
                        // 联动更新一下当前选中件的吸附位置
                        root.sync_inputs_to_memory();
                    }
                }
            }
        }

        // 底部动作按钮布局
        HorizontalLayout {
            spacing: 15px;

            // 删除按钮
            Button {
                text: "Delete Selected Key";
                enabled: root.selected_index != -1;
                clicked => {
                    root.delete_key(root.selected_index);
                    root.selected_index = -1; // 移除后清除选中高亮
                }
            }

            // 保存文件按钮
            Button {
                text: "Save Config";
                primary: true;
                clicked => {
                    root.save_config();
                }
            }
        }
    }

    TouchArea {
        visible: root.capturing_mode;
        width: parent.width;
        height: parent.height;
        x: 0;
        y: 0;
        enabled: root.capturing_mode;
    }

    // 辅助状态实时提交函数
    function sync_inputs_to_memory() {
        root.update_key_config(
            root.selected_index,
            root.current_x,
            root.current_y,
            root.current_w,
            root.current_h,
            root.current_color);
    }

    function save_config() {
        root.sync_inputs_to_memory();
        root.save_config_clicked();
    }
}

// KeyCaptureDialog.slint
export component KeyCaptureDialog inherits Window {
    // --- 窗口属性 ---
    no-frame: true;
    title: "Key Capture";
    background: #2b2b2b;
    width: 300px;
    height: 150px;
    always-on-top: true;
    //forward-focus: touch_area;
    
    // --- 定义回调：传递 rdev_name 和 display_name ---
    callback key-recorded(string, string);
    in-out property <string> detected-key: "Please press the key you wish to bind...";

    VerticalLayout {
        alignment: center;
        spacing: 10px;
        Text {
            text: root.detected-key;
            font-size: 16px;
            color: white;
            horizontal-alignment: center;
        }

        Text {
            text: "(Press ESC to cancel)";
            font-size: 12px;
            color: #aaaaaa;
            horizontal-alignment: center;
        }
    }
}

export component MainWindow inherits Window {
    title: "KeyTick";
    // 窗口大小现在最好也从 config 加载，或者设大一点
    width: Math.min(1200px, 20px + root.keys.length * 90px);
    height: 100px;
    background: transparent;
    no-frame: true;
    always-on-top: true;

    in property <[KeyData]> keys;
    callback request_close();
    callback gui_drag_window();
    callback request_settings();

    // 双击检测变量
    property <duration> last_click_time;

    TouchArea {
        pointer-event(event) => {
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.request_close();
            }
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                if (animation-tick() - root.last_click_time < 300ms) {
                    root.request_settings();
                } else {
                    root.gui_drag_window();
                }
                root.last_click_time = animation-tick();
            }
        }
    }

    // 放弃 Layout，使用容器手动定位
    for key_info in root.keys: Rectangle {
        // 关键：绑定坐标和尺寸
        x: key_info.x;
        y: key_info.y;
        width: key_info.w;
        height: key_info.h;

        background: key_info.is_pressed ? key_info.pressed_color : rgba(30, 30, 30, 0.8);
        border-radius: 8px;

        Text {
            text: key_info.display_name;
            color: white;
            font-size: key_info.h * 0.3; // 字体大小随高度自适应
        }
    }
}
