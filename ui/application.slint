import { Button, LineEdit, SpinBox } from "std-widgets.slint";

export struct KeyData {
    name: string,
    display_name: string,
    is_pressed: bool,
    x: length,
    y: length,
    w: length,
    h: length,
    pressed_color: color,
    color_hex: string,
    selected: bool, // ✨ 新增：标记在配置界面中是否被多选
}

export component SettingsWindow inherits Window {
    min-width: 600px;
    min-height: 450px;
    title: "KeyTick config";
    background: #252525;
    always-on-top: true;

    in property <[KeyData]> root_preview_keys;
    in-out property <int> selected_index: -1;

    in-out property <int> current_x;
    in-out property <int> current_y;
    in-out property <int> current_w;
    in-out property <int> current_h;
    in-out property <string> current_color;
    in-out property <bool> capturing_mode: false;
    in-out property <int> global_grid_size: 4;
    in-out property <int> global_top_boundary: 0;
    // ✨ 新增全局边框属性的暴露（用于在右侧或顶部面板设置）
    in-out property <int> global_border_width: 1;
    in-out property <color> global_border_color: #555555;
    in-out property <int> key_margin_width: 10;
    // ✨ 新增：全局点击偏移和选择状态
    in-out property <bool> has_active_selection: false;
    in-out property <int> click_offset_x: 0;
    in-out property <int> click_offset_y: 0;

    //callback update_key_config(int, int, int, int, int, string);
    // 替换原来单一的 callback update_key_config(...)
    callback update_key_position(int, int, int, int, int);   // index, x, y, canvas_w, canvas_h
    callback update_key_size(int, int, int);        // index, w, h
    callback update_key_color(int, string);         // index, color
    callback key_margin_edited(int);
    // ✨ 新增：画布点击回调，用于命中测试
    callback handle_canvas_pointer_down(int, int);  // click_canvas_x, click_canvas_y

    // ✨ 新增回调：当用户在配置窗口修改了边框值时通知后端
    callback global_border_edited(int, string);
    callback add_new_key();
    callback save_config_clicked();
    callback close_clicked();
    callback delete_key(int);            
    callback grid_size_edited(int);       
    callback top_boundary_edited(int);
    // ✨ 新增：通知后端某个索引的按键被点击了，并传入是否按下了 Ctrl 键以支持多选
    callback key_clicked_in_settings(int, bool);

    in-out property <bool> layout_settings_collapsed: false;

    VerticalLayout {
        padding: 15px;
        spacing: 15px;
        Text {
            text: "Location Preview (Drag to move, Click to select)";
            color: #aaa;
        }

        preview_box := Rectangle {
            min-height: 180px;
            min-width: 560px;
            background: #1a1a1a;
            clip: true;

            // 1. 将 TouchArea 铺满整个画布，作为全局鼠标事件拦截器
            canvas_ta := TouchArea {
                property <bool> is_dragging: false;

                pointer-event(event) => {
                    if (event.kind == PointerEventKind.down) {
                        // 将点击的绝对画布坐标发给后端去判断点中了谁
                        root.handle_canvas_pointer_down(Math.round(self.pressed-x / 1px), Math.round(self.pressed-y / 1px));
                    }
                    if (event.kind == PointerEventKind.up) {
                        // 释放鼠标时清除选择状态
                        root.has_active_selection = false;
                    }
                }

                moved => {
                    if (root.has_active_selection && self.pressed) {
                        // 此时 self.mouse-x 是相对于稳定不变的画布左上角的绝对坐标！
                        let pure_canvas_x = self.mouse-x / 1px;
                        let pure_canvas_y = self.mouse-y / 1px;

                        // 减去点击时在按键内的固定相对偏移 (该偏移在 pointer_down 时于后端存好)
                        let pure_target_x = pure_canvas_x - root.click_offset_x;
                        let pure_target_y = pure_canvas_y - root.click_offset_y;

                        root.update_key_position(
                            root.selected_index,
                            Math.round(pure_target_x),
                            Math.round(pure_target_y),
                            Math.round(preview_box.width / 1px),
                            Math.round(preview_box.height / 1px)
                        );
                    }
                }
            }

            // 2. 具体的按键渲染（仅负责呈现，内部不再放置带有移动逻辑的 TouchArea）
            for key[i] in root.root_preview_keys: Rectangle {
                x: key.x - root.key_margin_width * 1px;
                y: key.y - root.key_margin_width * 1px;
                width: key.w + root.key_margin_width * 2px;
                height: key.h + root.key_margin_width * 2px;
                clip: true;

                border-width: root.selected_index == i ? 3px : 1px;
                border-color: root.selected_index == i ? #00FFCC : #555555;
                background: root.selected_index == i ? #4A90E240 : transparent;

                Rectangle {
                    x: root.key_margin_width * 1px;
                    y: root.key_margin_width * 1px;
                    width: key.w;
                    height: key.h;
                    border-width: 1px;
                    border-color: #222222;
                    background: root.selected_index == i ? #4A90E2 : #444;

                    Text {
                        text: key.display_name;
                        color: white;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }

            Button {
                text: "+ Add Key";
                x: parent.width - 110px;
                y: parent.height - 40px;
                clicked => { root.add_new_key(); }
            }
        }

        Text {
            text: "Parameter Config";
            color: #aaa;
        }

        GridLayout {
            spacing: 10px;
            Row {
                Text { text: "Location X:"; vertical-alignment: center; color: white; }
                current_x_input := SpinBox {
                    value: root.current_x;
                    enabled: root.selected_index != -1;
                    minimum: 1;
                        edited => { 
                            root.current_x = self.value; 
                            root.update_key_position(root.selected_index, self.value, root.current_y, Math.round(preview_box.width / 1px), Math.round(preview_box.height / 1px));
                        }
                }
                Text { text: "Location Y:"; vertical-alignment: center; color: white; }
                current_y_input := SpinBox {
                    value: root.current_y;
                    enabled: root.selected_index != -1;
                    minimum: 1;
                        edited => { 
                            root.current_y = self.value; 
                            root.update_key_position(root.selected_index, root.current_x, self.value, Math.round(preview_box.width / 1px), Math.round(preview_box.height / 1px));
                        }
                }
            }

            Row {
                Text { text: "Width W:"; vertical-alignment: center; color: white; }
                current_w_input := SpinBox {
                    value: root.current_w;
                    enabled: root.selected_index != -1;
                    minimum: 1;
                    edited => { 
                        root.current_w = self.value; 
                        root.update_key_size(root.selected_index, self.value, root.current_h);
                    }
                }
                Text { text: "Height H:"; vertical-alignment: center; color: white; }
                current_h_input := SpinBox {
                    value: root.current_h;
                    enabled: root.selected_index != -1;
                    minimum: 1;
                    edited => { 
                        root.current_h = self.value; 
                        root.update_key_size(root.selected_index, root.current_w, self.value);
                    }
                }
            }

            Row {
                Text { text: "Pressed Color:"; vertical-alignment: center; color: white; }
                current_col_input := LineEdit {
                    text: root.current_color;
                    enabled: root.selected_index != -1;
                        edited => { 
                            root.current_color = self.text; 
                            root.update_key_color(root.selected_index, self.text);
                        }
                }
            }
            Row {
                Text { text: "Top Disappear Boundary (px):"; vertical-alignment: center; color: white; }
                SpinBox {
                    value: root.global_top_boundary;
                    minimum: 0; 
                    maximum: 800;
                    step-size: 10;
                    edited => {
                        root.global_top_boundary = self.value;
                        root.top_boundary_edited(self.value);
                    }
                }
            }

            Row {
                Text { text: "Global Grid Snapping (px):"; vertical-alignment: center; color: white; }
                SpinBox {
                    value: root.global_grid_size;
                    minimum: 1;
                    maximum: 50;
                    step-size: 1;
                    edited => {
                        root.global_grid_size = self.value;
                        root.grid_size_edited(self.value);
                        //root.sync_inputs_to_memory();
                    }
                }
            }
            Row {
                Text { text: "Key Margin Width (px):"; vertical-alignment: center; color: #fff; }
                SpinBox {
                    value: root.key_margin_width;
                    minimum: 0;
                    maximum: 100;
                    step-size: 1;
                    edited => {
                        root.key_margin_width = self.value;
                        root.key_margin_edited(self.value);
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 15px;
            Button {
                text: "Delete Selected Key";
                enabled: root.selected_index != -1;
                clicked => {
                    root.delete_key(root.selected_index);
                    root.selected_index = -1;
                }
            }

            Button {
                text: "Save Config & Close";
                primary: true;
                clicked => { root.save_config(); }
            }
        }
    }

    TouchArea {
        visible: root.capturing_mode;
        width: parent.width;
        height: parent.height;
        x: 0;
        y: 0;
        enabled: root.capturing_mode;
    }

    // function sync_inputs_to_memory() {
    //     root.update_key_config(
    //         root.selected_index,
    //         root.current_x,
    //         root.current_y,
    //         root.current_w,
    //         root.current_h,
    //         root.current_color);
    // }

    function save_config() {
        //root.sync_inputs_to_memory();
        root.save_config_clicked();
    }
}

export component KeyCaptureDialog inherits Window {
    no-frame: true;
    title: "Key Capture";
    background: #2b2b2b;
    width: 300px;
    height: 150px;
    always-on-top: true;
    callback key-recorded(string, string);
    in-out property <string> detected-key: "Please press the key you wish to bind...";
    VerticalLayout {
        alignment: center;
        spacing: 10px;
        Text {
            text: root.detected-key;
            font-size: 16px;
            color: white;
            horizontal-alignment: center;
        }

        Text {
            text: "(Press ESC to cancel)";
            font-size: 12px;
            color: #aaaaaa;
            horizontal-alignment: center;
        }
    }
}

export component MainWindow inherits Window {
    title: "KeyTick";
    width: root.window_width_px * 1px;
    height: root.window_height_px * 1px;
    background: transparent;
    no-frame: true;
    always-on-top: true;

    in property <[KeyData]> keys;
    in property <[KeyData]> bar_notes;
    // 注入 Rust 侧的边界配置
    in property <int> top_boundary_px: 300;
    // ✨ 新增：主窗口接收全局边框配置
    in property <int> global_border_width: 1;
    in property <color> global_border_color: #555555;
    in property <int> key_margin_width: 10;
    in property <int> window_width_px: 1200;
    in property <int> window_height_px: 500;

    callback request_close();
    callback gui_drag_window();
    callback request_settings();
    property <duration> last_click_time;

    Rectangle {
        width: 100%;
        height: 100%;
        clip: true; 
        background: transparent;
        
        TouchArea {
            width: 100%;
            height: 100%;
            pointer-event(event) => {
                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.request_close();
                }
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    if (animation-tick() - root.last_click_time < 300ms) {
                        root.request_settings();
                    } else {
                        root.gui_drag_window();
                    }
                    root.last_click_time = animation-tick();
                }
            }
        }

        // 循环绘制瀑布流长条动画
        for bar in root.bar_notes: Rectangle {
            x: bar.x;
            
            // ✨ 核心映射公式：
            // 因为 Slint 坐标系 0 在最顶部，而我们的物理 Y 轴 0 在底部。
            // parent.height - bar.y 会定位到长条的【底部边界】（即按键顶部）。
            // 再减去 bar.h (当前长条的高度)，就能精准让长条往上生长和飞升，彻底消除延迟感！
            y: parent.height - bar.y - bar.h;
            
            width: bar.w;
            height: bar.h;
            background: bar.pressed_color;
            //border-radius: 2px; // 让音符长条两端带点轻微圆角，视觉效果极佳
        }

        // 🟢 手动的物理按键绘制（固定在最底部）
        for key_info in root.keys: Rectangle {
            x: key_info.x;
            y: parent.height - key_info.h - key_info.y;
            width: key_info.w;
            height: key_info.h;
            background: key_info.is_pressed ? key_info.pressed_color : #33333330;
            // ✨ 实现方式：利用每个按键的位置 + 全局边框属性进行无缝渲染
            border-width: root.global_border_width * 1px;
            border-color: root.global_border_color;
            //border-radius: 4px;
            Text {
                text: key_info.display_name;
                color: white;
                font-size: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
    } 
}