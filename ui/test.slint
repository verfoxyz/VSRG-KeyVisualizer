
export component TestWindow inherits Window {
    width: 800px;
    height: 600px;
    title: "Layout Test Window";
    background: #252525;

    HorizontalLayout {
        // --- 左侧：列表容器 ---
        Rectangle {
            width: 200px;         // 固定宽度
            background: #1e1e1e;  // 深灰色背景用于视觉区分
            
            Text {
                text: "左侧列表区";
                color: white;
            }
        }

        // --- 右侧：工作区容器 ---
        VerticalLayout {
            horizontal-stretch: 1; // 关键：强制占满剩余空间
            spacing: 15px;
            padding: 15px;

            // 上方：预览区
            Rectangle {
                background: #1a1a1a;
                border-width: 1px;
                border-color: #444;
                
                Text {
                    text: "右侧预览区";
                    color: #888;
                }
            }

            // 下方：参数区
            Rectangle {
                height: 200px;    // 固定高度
                background: #1a1a1a;
                border-width: 1px;
                border-color: #444;
                
                Text {
                    text: "右侧参数区";
                    color: #888;
                }
            }
        }
    }
}