import { Button, ScrollView } from "std-widgets.slint";
import { KeyData } from "../key_data.slint";
import { ConfirmDeleteDialog, RenameDialog } from "../dialogs/dialogs.slint";
import { ProfilePanel } from "profile_panel.slint";
import { SettingsPreview } from "settings_preview.slint";

export component SettingsWindow inherits Window {
    min-height: 400px;
    min-width: 800px;
    title: "VSRG-KeyVisualizer config";
    background: #252525;
    always-on-top: true;

    // ===== 所有属性（保持与 Rust 端接口一致） =====
    in property <[KeyData]> root_preview_keys;
    in-out property <int> selected_index: -1;

    in-out property <int> current_x;
    in-out property <int> current_y;
    in-out property <int> current_w;
    in-out property <int> current_h;
    in-out property <string> current_color;
    in-out property <int> current_opacity_percent: 100;
    in-out property <int> current_bar_width_percent: 100;
    in-out property <bool> capturing_mode: false;
    in-out property <int> global_top_boundary: 0;
    in-out property <int> global_border_width: 1;
    in-out property <color> global_border_color: #ffffff;
    in-out property <string> global_border_color_hex: "#555555";
    in-out property <color> global_key_color: #333333;
    in-out property <string> global_key_color_hex: "#333333";
    in-out property <int> global_key_opacity_percent: 100;
    in-out property <int> key_margin_width: 4;
    in-out property <int> flow_direction: 0;
    in-out property <int> flow_speed: 4;
    in-out property <bool> front_line_emit: false;

    // Profile
    in property <[string]> profile_list;
    in-out property <int> profile_selected: -1;
    in property <string> current_profile_name;
    callback switch_to_profile(int);
    callback add_new_profile();
    callback rename_profile(int, string);
    callback delete_profile(int);
    in-out property <int> renaming_index: -1;
    in-out property <string> renaming_text;

    // 事件回调
    callback handle_canvas_pointer_down(int, int, bool);
    callback update_key_position(int, int, int, int, int);
    callback update_key_position_x(int, int, int, int);
    callback update_key_position_y(int, int, int, int);
    callback top_boundary_edited(int);
    callback key_margin_edited(int);
    callback add_new_key();
    callback save_config();
    callback update_key_size(int, int, int);
    callback update_key_color(int, string);
    callback update_key_opacity(int, int);
    callback border_color_edited(string);
    callback key_color_edited(string);
    callback key_opacity_edited(int);
    callback flow_direction_edited(int);
    callback flow_speed_edited(int);
    callback front_line_emit_toggled(bool);
    callback delete_key(int);
    callback update_key_bar_width_percent(int, int);
    callback delete_selected_keys();
    in-out property <bool> confirm_delete_visible: false;

    // 独立参数面板窗口（由外部 Rust 管理）
    in-out property <bool> panel_window_open: false;
    callback toggle_param_panel();
    // 配置是否已修改（控制保存按钮文本）
    in-out property <bool> config_dirty: false;
    callback mark_dirty();
    // 左侧 Profile 列表展开/折叠（默认折叠）
    in-out property <bool> profile_expanded: false;

    HorizontalLayout {
        padding: 15px;
        spacing: 15px;

        // ====== 左侧：Profile 列表（可折叠，默认折叠） ======
        if root.profile_expanded : ProfilePanel {
            profile_list <=> root.profile_list;
            profile_selected <=> root.profile_selected;
            current_profile_name <=> root.current_profile_name;
            switch_to_profile(index) => { root.switch_to_profile(index); }
            add_new_profile => { root.add_new_profile(); }
            rename_profile(index, name) => { root.rename_profile(index, name); }
            delete_profile(index) => { root.delete_profile(index); }
            renaming_index <=> root.renaming_index;
            renaming_text <=> root.renaming_text;
        }
        if !root.profile_expanded : Rectangle {
            width: 24px;
            background: #1e1e1e;
            border-radius: 6px;
            TouchArea {
                width: 100%;
                height: 100%;
                clicked => { root.profile_expanded = true; }
            }
            Text {
                text: "▶";
                color: #888;
                font-size: 14px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // ====== 右侧容器：画布预览 + 浮动参数面板 ======
        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
            clip: false;

            HorizontalLayout {
                spacing: 4px;
                // ⭐ Profile 折叠切换条（仅展开时显示收缩按钮）
                if root.profile_expanded : Rectangle {
                    width: 20px;
                    background: #1e1e1e;
                    border-radius: 4px;
                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.profile_expanded = false; }
                    }
                    Text {
                        text: "◀";
                        color: #888;
                        font-size: 14px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }

                VerticalLayout {
                    spacing: 15px;
                    horizontal-stretch: 1;

                    // ⭐ "Location Preview" 文本 + 面板切换按钮
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Location Preview (Drag to move, Click to select)";
                            color: #aaa;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: root.panel_window_open ? "Hide Panel" : "Show Panel";
                            clicked => { root.toggle_param_panel(); }
                        }
                    }

                    preview_box := SettingsPreview {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        preview_keys <=> root.root_preview_keys;
                        key_margin_width <=> root.key_margin_width;
                        global_key_color <=> root.global_key_color;
                        selected_index <=> root.selected_index;
                        canvas_enabled: true;
                        handle_canvas_pointer_down(x, y, ctrl) => { root.handle_canvas_pointer_down(x, y, ctrl); }
                        update_key_position(idx, mx, my, cw, ch) => { root.update_key_position(idx, mx, my, cw, ch); }
                        add_new_key => { root.add_new_key(); }
                        request_focus => { key_handler.focus(); }
                    }

                    // ⭐ 操作按钮（画布预览下方靠左）
                    HorizontalLayout {
                        spacing: 15px;
                        Button {
                            text: "Delete Selected Key";
                            enabled: root.selected_index != -1;
                            clicked => { root.confirm_delete_visible = true; }
                        }
                        Button {
                            text: root.config_dirty ? "Save Config" : "Close";
                            primary: root.config_dirty;
                            clicked => { root.save_config(); }
                        }
                    }
                }
            }

            key_handler := FocusScope {
                enabled: root.selected_index != -1;
                key-pressed(ev) => {
                    if (ev.text == "" || ev.text == "\u{7f}") {
                        root.confirm_delete_visible = true;
                        accept
                    } else { reject }
                }
            } // ~ key_handler
    } // ~ 右侧容器 Rectangle
} // ~ HorizontalLayout (外层)

    // ====== 弹窗 ======
    ConfirmDeleteDialog {
        is_visible: root.confirm_delete_visible;
        confirmed => {
            root.confirm_delete_visible = false;
            root.delete_selected_keys();
        }
        cancelled => { root.confirm_delete_visible = false; }
    }

    RenameDialog {
        is_visible: root.renaming_index >= 0;
        current_name: root.renaming_text;
        edit_text: root.renaming_text;
        accepted(new_name) => {
            root.rename_profile(root.renaming_index, new_name);
            root.renaming_index = -1;
        }
        cancelled => { root.renaming_index = -1; }
    }

    // 按键捕获模式遮罩层
    TouchArea {
        visible: root.capturing_mode;
        width: parent.width;
        height: parent.height;
        x: 0;
        y: 0;
        enabled: root.capturing_mode;
    }
} // ~ SettingsWindow
