import { KeyData } from "key_data.slint";

export component MainWindow inherits Window {
    title: "VSRG-KeyVisualizer";
    width: root.window_width_px * 1px;
    height: root.window_height_px * 1px;
    background: transparent;
    no-frame: true;
    always-on-top: true;

    in property <[KeyData]> keys;
    in property <[KeyData]> bar_notes;
    in property <int> top_boundary_px: 300;
    in property <int> global_border_width: 1;
    in property <color> global_border_color: #555555;
    in property <color> global_key_color: #333333;
    in property <int> key_margin_width: 10;
    in property <int> window_width_px: 1200;
    in property <int> window_height_px: 500;
    in property <int> key_area_height: 100;
    // 瀑布流方向：0=下 1=上 2=左 3=右
    in property <int> flow_direction: 0;
    // 调试覆盖层：由 Rust 端根据日志级别控制（DEBUG 级别显示）
    // 或通过 Lint 宏 cfg(feature = "debug_overlay") 在编译时彻底移除
    in property <bool> show_debug_overlay: false;

    callback request_close();
    callback gui_click(int, int);
    callback request_settings();
    callback gui_drag_window();

    property <length> canvas_width: root.window_width_px * 1px;
    property <length> canvas_height: root.window_height_px * 1px;
    property <length> key_area_top: root.canvas_height - root.key_area_height * 1px;

    // =========================================================================
    // 按键坐标：所有方向使用统一左上角坐标系，永不翻转
    // 瀑布流方向仅影响音符的生成位置和运动方向（events.rs 控制）
    // =========================================================================
    function key-x(key: KeyData) -> length {
        if root.flow_direction == 2 {
            // ←：按键右移 top_boundary，给音符向左流动的空间
            return root.top_boundary_px * 1px + root.canvas_width * key.anchor_ratio_x;
        }
        return root.canvas_width * key.anchor_ratio_x;
    }
    function key-y(key: KeyData) -> length {
        if root.flow_direction == 1 {
            // ↑：按键下移 top_boundary，给音符向上流动的空间
            return root.top_boundary_px * 1px + root.canvas_height * key.anchor_ratio_y;
        }
        return root.canvas_height * key.anchor_ratio_y;
    }
    // 所有方向的 notes 都使用直接坐标渲染（与 direction 0 相同坐标系）
    // 坐标转换在 events.rs 中创建 BarNote 时完成
    function note-x(bar: KeyData) -> length { return bar.x; }
    function note-y(bar: KeyData) -> length { return bar.y; }

    // =========================================================================
    // 所有子元素平铺在根节点下（无全屏容器 Rectangle），
    // 避免 Slint 局部脏矩形优化破坏 OS 级透明窗口的像素合成。
    // keys.length 绑定确保几何依赖触发重绘。
    // =========================================================================
    //层级 0：调试用矩形（显示画布尺寸）
    // visible 由 Rust 端通过 show_debug_overlay 控制，仅 DEBUG 日志级别时显示
    Rectangle {
        visible: root.show_debug_overlay;
        width: root.canvas_width;
        height: root.canvas_height;
        
        border-width: 1px;
        border-color: #ff0000;
        //background: #000000;
        init => {
            debug("[MainWindow] canvas_width:", root.canvas_width / 1px, "px, canvas_height:", root.canvas_height / 1px, "px");
        }
    }
    // Debug: 输出 canvas_width 和 canvas_height（使用 Slint 内置 debug 函数）
    

    // 层级 1：瀑布流音符（在按键上方渲染，确保不被按键遮挡）
    for bar in root.bar_notes: Rectangle {
        x: root.note-x(bar);
        y: root.note-y(bar);
        width: bar.w;
        height: bar.h;
        background: bar.pressed_color;
    }


    // 层级 2：按键（通过比例锚点响应画布尺寸变化）
    for key_info in root.keys: Rectangle {
        x: root.key-x(key_info);
        y: root.key-y(key_info);
        width: key_info.w;
        height: key_info.h;
        background: key_info.is_pressed ? key_info.pressed_color : root.global_key_color;
        border-width: root.global_border_width * 1px;
        border-color: root.global_border_color;
        Text {
            text: key_info.display_name;
            color: white;
            font-size: 18px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }

    // 层级 3：交互 TouchArea（覆盖整个画布以支持所有方向拖拽）
    TouchArea {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 100%;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.gui_click(
                    Math.round(self.pressed-x / 1px),
                    Math.round(self.pressed-y / 1px)
                );
            }
            else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                // 右键弹出菜单（使用 mouse-x/y 而非 pressed-x/y，因为右键不更新 pressed 位置）
                root.context_menu_x = self.mouse-x;
                root.context_menu_y = self.mouse-y;
                context_menu.show();
            }
            
        }
        moved => {
            if (self.pressed) {
                root.gui_drag_window();
            }
        }
    }

    // 右键菜单坐标
    property <length> context_menu_x: 0px;
    property <length> context_menu_y: 0px;

    // 层级 4：右键上下文菜单
    context_menu := PopupWindow {
        x: root.context_menu_x;
        y: root.context_menu_y;
        width: 160px;

        Rectangle {
            background: #2b2b2b;
            border-radius: 6px;
            border-width: 1px;
            border-color: #555555;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                // 示例：将菜单项的 Rectangle 修改为支持状态高亮
                TouchArea {
                    height: 32px;
                    // 使用变量暂存 hover 和 pressed 状态
                    property <bool> is_hovered: self.has-hover;
                    property <bool> is_pressed: self.pressed;

                    clicked => {
                        context_menu.close();
                        root.request_settings();
                    }
                    
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        // 核心：点击时变深色，悬停时变浅色，平时透明
                        background: is_pressed ? #444444 : (is_hovered ? #3a3a3a : transparent);
                        border-radius: 4px; // 加上圆角更自然
                        
                        Text {
                            x: 10px;
                            text: "打开配置";
                            color: white;
                            vertical-alignment: center;
                            font-size: 14px;
                        }
                    }
                }

                // 分隔线
                Rectangle {
                    height: 1px;
                    width: 100%;
                    background: #555555;
                }

                // 选项 2：关闭
                TouchArea {
                    height: 32px;
                    clicked => {
                        context_menu.close();
                        root.request_close();
                    }
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        background: transparent;
                        Text {
                            x: 10px;
                            text: "关闭";
                            color: #ff6666;
                            vertical-alignment: center;
                            font-size: 14px;
                        }
                    }
                }
            }
        }
    }
}